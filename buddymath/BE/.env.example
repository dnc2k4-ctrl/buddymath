# ══════════════════════════════════════════════════════
#  BuddyMath BE — Sao chép thành .env và điền giá trị thực
# ══════════════════════════════════════════════════════

# ── Groq (LLM cho chat / classroom / synthesis) ───────
# Lấy tại: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_VISION_MODELS=model-a,model-b   # bổ sung model vision tuỳ chọn

# ── Jina AI (embedding cho RAG) ───────────────────────
# Lấy tại: https://jina.ai/embeddings/
JINA_API_KEY=jina_xxxxxxxxxxxxxxxxxxxx
JINA_MODEL=jina-embeddings-v3

# ── Claude (proxy tuỳ chọn, không bắt buộc) ───────────
# CLAUDE_API_KEY=sk-ant-api03-xxxx
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Pipeline tuning ───────────────────────────────────
LLM_TIMEOUT=60
RAG_TOP_K=5
HISTORY_WINDOW=10

# ── JWT ───────────────────────────────────────────────
# Tạo: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=thay-bang-chuoi-ngau-nhien-32-ky-tu
ACCESS_TOKEN_EXPIRE_HOURS=168

# ── Database (mặc định SQLite trong BE/) ──────────────
# DATABASE_URL=sqlite:///./smartbuddy.db

# ── Email (báo cáo phụ huynh — tuỳ chọn) ──────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-16-chars
FROM_EMAIL=SmartBuddy <your-email@gmail.com>

# ── URL công khai (dùng trong link email) ─────────────
PUBLIC_BASE_URL=http://localhost:8000

# ── Đường dẫn (tuỳ chọn — mặc định trỏ tới FE/ và BE/data) ──
# FRONTEND_DIR=../FE
# DATA_ROOT=./data
